{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "GrainFS raft v2 staging soak — 14-day observability dashboard. Tracks boundary metrics (adapter layer) and actor-internal metrics for divergence detection vs v1.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum by (outcome) (rate(grainfs_raft_v2_propose_total[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "title": "Propose throughput (rate/min by outcome)",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(grainfs_raft_v2_propose_latency_seconds_bucket[1m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": "${datasource}",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(grainfs_raft_v2_propose_latency_seconds_bucket[1m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": "${datasource}",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(grainfs_raft_v2_propose_latency_seconds_bucket[1m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Propose latency p50/p95/p99",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "rate(grainfs_raft_v2_actor_leader_transitions_total[1m])",
          "legendFormat": "transitions/min",
          "refId": "A"
        }
      ],
      "title": "Leader transitions per minute",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "rate(grainfs_raft_v2_actor_term_bumps_total[1m])",
          "legendFormat": "term bumps/min",
          "refId": "A"
        }
      ],
      "title": "Term bumps per minute",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "grainfs_raft_v2_actor_cmd_ch_depth",
          "legendFormat": "cmdCh depth",
          "refId": "A"
        }
      ],
      "title": "Actor cmdCh depth (sampled on heartbeat tick)",
      "description": "Sampled on heartbeat tick in Leader state only. Value is 0 on single-voter or non-leader nodes.",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1 },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "histogram_quantile(0.99, sum by (le, outcome) (rate(grainfs_raft_v2_actor_append_entries_duration_seconds_bucket[1m])))",
          "legendFormat": "p99 {{outcome}}",
          "refId": "A"
        }
      ],
      "title": "AppendEntries RPC duration p99 by outcome",
      "type": "timeseries"
    },
    {
      "datasource": "${datasource}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "stacking": { "group": "A", "mode": "normal" } }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 7,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": "${datasource}",
          "expr": "sum by (outcome) (increase(grainfs_raft_v2_bootstrap_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "title": "v2 Bootstrap outcomes (5m window)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["grainfs", "raft", "v2", "soak"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      }
    ]
  },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "GrainFS raft v2 — staging soak",
  "uid": "grainfs-raftv2-soak",
  "version": 1
}
